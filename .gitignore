# =========================
# 1. Virtual Environments
# =========================
# Ignore uv and standard python environments
.venv/
venv/
env/

# =========================
# 2. Python Cache
# =========================
# Prevents cloud conflicts with pre-compiled local code
__pycache__/
*.py[cod]
*$py.class
.pytest_cache/

# =========================
# 3. Security / Secrets
# =========================
# NEVER push your API keys or AWS credentials to GitHub!
.env
*.pem
secrets.json

# =========================
# 4. Large Data & Notebooks
# =========================
# Ignore massive video files and Jupyter caches
*.mp4
*.avi
*.mov
.ipynb_checkpoints/
data/
datasets/

# =========================
# 5. ML Models & Weights
# =========================
# Ignore heavy training checkpoints and raw arrays
*.npy
*.npz
best_model.weights.h5
train_features.npy
train_labels.npy

# NOTE: We specifically DO NOT ignore deepfake_video_model.h5 here 
# because your Render server needs it to run the API!

# =========================
# 6. OS & IDE Files
# =========================
# Ignore annoying hidden files generated by Mac/Windows and editors
.DS_Store
Thumbs.db
.vscode/
.idea/